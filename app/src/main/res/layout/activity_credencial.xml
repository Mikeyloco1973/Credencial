<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Fondo con logo HP semitransparente -->
    <ImageView
        android:id="@+id/bgHP"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.1"
        android:contentDescription="Logo HP de fondo"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_hp_logo" />

    <!-- Logo ServiceOne más arriba y más pequeño -->

    <!-- Foto del técnico -->

    <ImageView
        android:id="@+id/logoServiceOne"
        android:layout_width="275dp"
        android:layout_height="77dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="228dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="228dp"
        android:contentDescription="Logo ServiceOne"
        android:src="@drawable/splash_serviceone" />

    <ImageView
        android:id="@+id/imgFoto"
        android:layout_width="180dp"
        android:layout_height="220dp"
        android:layout_marginTop="120dp"
        android:layout_marginLeft="30dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_launcher_foreground"
        android:contentDescription="Foto Técnico"/>

    <!-- Datos del técnico en dos columnas -->
    <LinearLayout
        android:id="@+id/layoutDatos"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toRightOf="@id/imgFoto"
        android:layout_marginLeft="40dp"
        android:layout_marginTop="120dp">

        <!-- Fila Nombres / Apellidos -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:weightSum="2">

            <!-- Columna Nombres -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/labelNombres"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nombres:"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary"/>

                <TextView
                    android:id="@+id/tvNombres"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textColor="?android:attr/textColorPrimary"/>
            </LinearLayout>

            <!-- Columna Apellidos -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/labelApellidos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Apellidos:"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary"/>

                <TextView
                    android:id="@+id/tvApellidos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textColor="?android:attr/textColorPrimary"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Fila Rut / Cargo -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:weightSum="2"
            android:layout_marginTop="20dp">

            <!-- Columna Rut -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/labelRut"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Rut:"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary"/>

                <TextView
                    android:id="@+id/tvRut"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textColor="?android:attr/textColorPrimary"/>
            </LinearLayout>

            <!-- Columna Cargo -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/labelCargo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cargo:"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary"/>

                <TextView
                    android:id="@+id/tvCargo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textColor="?android:attr/textColorPrimary"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Footer centrado con texto y logo HP -->
    <LinearLayout
        android:id="@+id/layoutFooter"
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="20dp"
        android:gravity="center">

        <TextView
            android:id="@+id/tvFooter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Prestando servicios para "
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"/>

        <ImageView
            android:id="@+id/logoHP"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_hp_logo"
            android:contentDescription="Logo HP"/>
    </LinearLayout>

</RelativeLayout>
